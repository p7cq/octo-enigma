		i2c@2180000 {
			compatible = "fsl,ls1046a-i2c", "fsl,vf610-i2c";
			#address-cells = <0x01>;
			#size-cells = <0x00>;
			reg = <0x00 0x2180000 0x00 0x10000>;
			interrupts = <0x00 0x38 0x04>;
			clocks = <0x02 0x04 0x01>;
			dmas = <0x10 0x01 0x26 0x10 0x01 0x27>;
			dma-names = "rx", "tx";
			status = "okay";
			dma-coherent;

			i2c-mux@70 {
				compatible = "nxp,pca9545";
				reg = <0x70>;
				#address-cells = <0x01>;
				#size-cells = <0x00>;

				i2c@0 {
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					reg = <0x00>;

					retimer@18 {
						compatible = "ti,ds100df410";
						reg = <0x18>;
						status = "okay";
					};
				};

				i2c@1 {
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					reg = <0x01>;

					temp-sensor@4c {
						compatible = "ti,tmp431";
						reg = <0x4c>;
					};
				};

				i2c@2 {
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					reg = <0x02>;

					temp-sensor@4c {
						compatible = "ti,tmp431";
						reg = <0x4c>;
					};
				};

				i2c@3 {
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					reg = <0x03>;

					fan-controller@2e {
						compatible = "microchip,emc2305";
						reg = <0x2e>;
						#address-cells = <0x01>;
						#size-cells = <0x00>;
						#pwm-cells = <0x03>;
						phandle = <0x11>;

						fan@0 {
							reg = <0x00>;
							label = "System Fan 1";
							pwms = <0x11 0x6590 0x01 0x01>;
							#cooling-cells = <0x02>;
						};

						fan@1 {
							reg = <0x01>;
							label = "System Fan 2";
							pwms = <0x11 0x6590 0x01 0x01>;
							#cooling-cells = <0x02>;
						};
					};
				};
			};
		};

		i2c@2190000 {
			compatible = "fsl,ls1046a-i2c", "fsl,vf610-i2c";
