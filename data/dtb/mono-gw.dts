/dts-v1/;

/ {
	compatible = "mono,gateway-dk", "fsl,ls1046a";
	interrupt-parent = <0x01>;
	#address-cells = <0x02>;
	#size-cells = <0x02>;
	model = "Mono Gateway Development Kit";

	psci {
		status = "okay";
		method = "smc";
		compatible = "arm,psci-1.0", "arm,psci-0.2";
	};

	aliases {
		crypto = "/soc/crypto@1700000";
		fman0 = "/soc/fman@1a00000";
		ethernet0 = "/soc/fman@1a00000/ethernet@e8000";
		ethernet1 = "/soc/fman@1a00000/ethernet@ea000";
		ethernet2 = "/soc/fman@1a00000/ethernet@e2000";
		ethernet3 = "/soc/fman@1a00000/ethernet@f0000";
		ethernet4 = "/soc/fman@1a00000/ethernet@f2000";
		ethernet5 = "/soc/fman@1a00000/ethernet@ea000";
		ethernet6 = "/soc/fman@1a00000/ethernet@f0000";
		ethernet7 = "/soc/fman@1a00000/ethernet@f2000";
		rtc1 = "/soc/rtc@29d0000";
		qman_fqd = "/reserved-memory/qman-fqd";
		bman_fbpr = "/reserved-memory/bman-fbpr";
		qman_pfdr = "/reserved-memory/qman-pfdr";
		serial0 = "/soc/serial@21c0500";
		serial1 = "/soc/serial@21c0600";
	};

	cpus {
		#address-cells = <0x01>;
		#size-cells = <0x00>;

		cpu@0 {
			enable-method = "psci";
			device_type = "cpu";
			compatible = "arm,cortex-a72";
			reg = <0x00>;
			clocks = <0x02 0x01 0x00>;
			next-level-cache = <0x03>;
			cpu-idle-states = <0x04>;
			#cooling-cells = <0x02>;
			phandle = <0x08>;
		};

		cpu@1 {
			enable-method = "psci";
			device_type = "cpu";
			compatible = "arm,cortex-a72";
			reg = <0x01>;
			clocks = <0x02 0x01 0x00>;
			next-level-cache = <0x03>;
			cpu-idle-states = <0x04>;
			#cooling-cells = <0x02>;
			phandle = <0x09>;
		};

		cpu@2 {
			enable-method = "psci";
			device_type = "cpu";
			compatible = "arm,cortex-a72";
			reg = <0x02>;
			clocks = <0x02 0x01 0x00>;
			next-level-cache = <0x03>;
			cpu-idle-states = <0x04>;
			#cooling-cells = <0x02>;
			phandle = <0x0a>;
		};

		cpu@3 {
			enable-method = "psci";
			device_type = "cpu";
			compatible = "arm,cortex-a72";
			reg = <0x03>;
			clocks = <0x02 0x01 0x00>;
			next-level-cache = <0x03>;
			cpu-idle-states = <0x04>;
			#cooling-cells = <0x02>;
			phandle = <0x0b>;
		};

		l2-cache {
			compatible = "cache";
			cache-level = <0x02>;
			cache-unified;
			phandle = <0x03>;
		};

		fman0-extended-args {
			cell-index = <0x00>;
			compatible = "fsl,fman-extended-args";
			total-fifo-size = <0x3e500>;

			fman0_oh_0x3-extended-args {
				cell-index = <0x01>;
				compatible = "fsl,fman-port-op-extended-args";
				fifo-size = <0x3200 0x00>;
				buffer-layout = <0x60 0x40>;
			};

			fman0_oh_0x4-extended-args {
				cell-index = <0x02>;
				compatible = "fsl,fman-port-op-extended-args";
				fifo-size = <0x900 0x00>;
				buffer-layout = <0x60 0x40>;
			};

			fman0_rx0-extended-args {
				cell-index = <0x00>;
				compatible = "fsl,fman-port-1g-rx-extended-args";
				fifo-size = <0x3200 0x00>;
				buffer-layout = <0x60 0x40>;
				vsp-window = <0x02 0x00>;
			};

			fman0_tx0-extended-args {
				cell-index = <0x00>;
				compatible = "fsl,fman-port-1g-tx-extended-args";
				fifo-size = <0x3200 0x00>;
				buffer-layout = <0x60 0x40>;
			};

			fman0_rx1-extended-args {
				cell-index = <0x01>;
				compatible = "fsl,fman-port-1g-rx-extended-args";
				fifo-size = <0x3200 0x00>;
				buffer-layout = <0x60 0x40>;
				vsp-window = <0x02 0x00>;
			};

			fman0_tx1-extended-args {
				cell-index = <0x01>;
				compatible = "fsl,fman-port-1g-tx-extended-args";
				fifo-size = <0x3200 0x00>;
				buffer-layout = <0x60 0x40>;
			};

			fman0_rx2-extended-args {
				cell-index = <0x02>;
				compatible = "fsl,fman-port-1g-rx-extended-args";
				fifo-size = <0x3200 0x00>;
				buffer-layout = <0x60 0x40>;
				vsp-window = <0x02 0x00>;
			};

			fman0_tx2-extended-args {
				cell-index = <0x02>;
				compatible = "fsl,fman-port-1g-tx-extended-args";
				fifo-size = <0x3200 0x00>;
				buffer-layout = <0x60 0x40>;
			};

			fman0_rx3-extended-args {
				cell-index = <0x03>;
				compatible = "fsl,fman-port-1g-rx-extended-args";
				fifo-size = <0x3200 0x00>;
				buffer-layout = <0x60 0x40>;
				vsp-window = <0x02 0x00>;
			};

			fman0_tx3-extended-args {
				cell-index = <0x03>;
				compatible = "fsl,fman-port-1g-tx-extended-args";
				fifo-size = <0x3200 0x00>;
				buffer-layout = <0x60 0x40>;
			};

			fman0_rx4-extended-args {
				cell-index = <0x04>;
				compatible = "fsl,fman-port-1g-rx-extended-args";
				fifo-size = <0x3200 0x00>;
				buffer-layout = <0x60 0x40>;
				vsp-window = <0x02 0x00>;
			};

			fman0_tx4-extended-args {
				cell-index = <0x04>;
				compatible = "fsl,fman-port-1g-tx-extended-args";
				fifo-size = <0x3200 0x00>;
				buffer-layout = <0x60 0x40>;
			};

			fman0_rx5-extended-args {
				cell-index = <0x05>;
				compatible = "fsl,fman-port-1g-rx-extended-args";
				fifo-size = <0x3200 0x00>;
				buffer-layout = <0x60 0x40>;
				vsp-window = <0x02 0x00>;
			};

			fman0_tx5-extended-args {
				cell-index = <0x05>;
				compatible = "fsl,fman-port-1g-tx-extended-args";
				fifo-size = <0x3200 0x00>;
				buffer-layout = <0x60 0x40>;
			};

			fman0_rx6-extended-args {
				cell-index = <0x00>;
				compatible = "fsl,fman-port-10g-rx-extended-args";
				fifo-size = <0x6000 0x00>;
				buffer-layout = <0x60 0x40>;
				vsp-window = <0x02 0x00>;
			};

			fman0_tx6-extended-args {
				cell-index = <0x00>;
				compatible = "fsl,fman-port-10g-tx-extended-args";
				fifo-size = <0x4000 0x00>;
				buffer-layout = <0x60 0x40>;
			};

			fman0_rx7-extended-args {
				cell-index = <0x01>;
				compatible = "fsl,fman-port-10g-rx-extended-args";
				fifo-size = <0x6000 0x00>;
				buffer-layout = <0x60 0x40>;
				vsp-window = <0x02 0x00>;
			};

			fman0_tx7-extended-args {
				cell-index = <0x01>;
				compatible = "fsl,fman-port-10g-tx-extended-args";
				fifo-size = <0x4000 0x00>;
				buffer-layout = <0x60 0x40>;
			};
		};
	};

	idle-states {
		entry-method = "psci";

		cpu-ph20 {
			compatible = "arm,idle-state";
			idle-state-name = "PH20";
			arm,psci-suspend-param = <0x00>;
			entry-latency-us = <0x3e8>;
			exit-latency-us = <0x3e8>;
			min-residency-us = <0xbb8>;
			phandle = <0x04>;
		};
	};

	memory@80000000 {
		device_type = "memory";
		reg = <0x00 0x80000000 0x00 0x7be00000 0x08 0x80000000 0x01 0x80000000>;
	};

	sysclk {
		compatible = "fixed-clock";
		#clock-cells = <0x00>;
		clock-frequency = <0x5f5e100>;
		clock-output-names = "sysclk";
		phandle = <0x0f>;
	};

	reboot {
		compatible = "syscon-reboot";
		regmap = <0x05>;
		offset = <0xb0>;
		mask = <0x02>;
	};

	thermal-zones {

		ddr-thermal {
			polling-delay-passive = <0x3e8>;
			polling-delay = <0x1388>;
			thermal-sensors = <0x06 0x00>;

			trips {

				ddr-ctrler-alert {
					temperature = <0x14c08>;
					hysteresis = <0x7d0>;
					type = "passive";
				};

				ddr-ctrler-crit {
					temperature = <0x17318>;
					hysteresis = <0x7d0>;
					type = "critical";
				};
			};
		};

		serdes-thermal {
			polling-delay-passive = <0x3e8>;
			polling-delay = <0x1388>;
			thermal-sensors = <0x06 0x01>;

			trips {

				serdes-alert {
					temperature = <0x14c08>;
					hysteresis = <0x7d0>;
					type = "passive";
				};

				serdes-crit {
					temperature = <0x17318>;
					hysteresis = <0x7d0>;
					type = "critical";
				};
			};
		};

		fman-thermal {
			polling-delay-passive = <0x3e8>;
			polling-delay = <0x1388>;
			thermal-sensors = <0x06 0x02>;

			trips {

				fman-alert {
					temperature = <0x14c08>;
					hysteresis = <0x7d0>;
					type = "passive";
				};

				fman-crit {
					temperature = <0x17318>;
					hysteresis = <0x7d0>;
					type = "critical";
				};
			};
		};

		cluster-thermal {
			polling-delay-passive = <0x3e8>;
			polling-delay = <0x1388>;
			thermal-sensors = <0x06 0x03>;

			trips {

				core-cluster-alert {
					temperature = <0x14c08>;
					hysteresis = <0x7d0>;
					type = "passive";
					phandle = <0x07>;
				};

				core-cluster-crit {
					temperature = <0x17318>;
					hysteresis = <0x7d0>;
					type = "critical";
				};
			};

			cooling-maps {

				map0 {
					trip = <0x07>;
					cooling-device = <0x08 0xffffffff 0xffffffff 0x09 0xffffffff 0xffffffff 0x0a 0xffffffff 0xffffffff 0x0b 0xffffffff 0xffffffff>;
				};
			};
		};

		sec-thermal {
			polling-delay-passive = <0x3e8>;
			polling-delay = <0x1388>;
			thermal-sensors = <0x06 0x04>;

			trips {

				sec-alert {
					temperature = <0x14c08>;
					hysteresis = <0x7d0>;
					type = "passive";
				};

				sec-crit {
					temperature = <0x17318>;
					hysteresis = <0x7d0>;
					type = "critical";
				};
			};
		};
	};

	timer {
		compatible = "arm,armv8-timer";
		interrupts = <0x01 0x0d 0xf08 0x01 0x0e 0xf08 0x01 0x0b 0xf08 0x01 0x0a 0xf08>;
	};

	pmu {
		compatible = "arm,cortex-a72-pmu";
		interrupts = <0x00 0x6a 0x04 0x00 0x6b 0x04 0x00 0x5f 0x04 0x00 0x61 0x04>;
		interrupt-affinity = <0x08 0x09 0x0a 0x0b>;
	};

	interrupt-controller@1400000 {
		compatible = "arm,gic-400";
		#interrupt-cells = <0x03>;
		interrupt-controller;
		reg = <0x00 0x1410000 0x00 0x10000 0x00 0x1420000 0x00 0x20000 0x00 0x1440000 0x00 0x20000 0x00 0x1460000 0x00 0x20000>;
		interrupts = <0x01 0x09 0xf08>;
		phandle = <0x01>;
	};

	soc {
		compatible = "simple-bus";
		#address-cells = <0x02>;
		#size-cells = <0x02>;
		ranges;
		dma-ranges = <0x00 0x00 0x00 0x00 0x10000 0x00>;

		memory-controller@1080000 {
			compatible = "fsl,qoriq-memory-controller";
			reg = <0x00 0x1080000 0x00 0x1000>;
			interrupts = <0x00 0x90 0x04>;
			dma-coherent;
		};

		memory-controller@1530000 {
			compatible = "fsl,ifc";
			reg = <0x00 0x1530000 0x00 0x10000>;
			interrupts = <0x00 0x2b 0x04>;
			status = "disabled";
			dma-coherent;
		};

		spi@1550000 {
			compatible = "fsl,ls1021a-qspi";
			#address-cells = <0x01>;
			#size-cells = <0x00>;
			reg = <0x00 0x1550000 0x00 0x10000 0x00 0x40000000 0x00 0x10000000>;
			reg-names = "QuadSPI", "QuadSPI-memory";
			interrupts = <0x00 0x63 0x04>;
			clock-names = "qspi_en", "qspi";
			clocks = <0x02 0x04 0x01 0x02 0x04 0x01>;
			status = "okay";
			dma-coherent;

			flash@0 {
				#address-cells = <0x01>;
				#size-cells = <0x01>;
				compatible = "jedec,spi-nor";
				spi-max-frequency = <0x2faf080>;
				reg = <0x00>;

				partitions {
					compatible = "fixed-partitions";
					#address-cells = <0x01>;
					#size-cells = <0x01>;

					partition@flash {
						label = "flash";
						reg = <0x00 0x4000000>;
					};

					partition@0 {
						label = "rcw-bl2";
						reg = <0x00 0x100000>;
					};

					partition@100000 {
						label = "uboot";
						reg = <0x100000 0x200000>;
					};

					partition@300000 {
						label = "uboot-env";
						reg = <0x300000 0x100000>;
					};

					partition@400000 {
						label = "fman-ucode";
						reg = <0x400000 0x100000>;
					};

					partition@500000 {
						label = "recovery-dtb";
						reg = <0x500000 0x100000>;
					};

					partition@600000 {
						label = "backup";
						reg = <0x600000 0x400000>;
					};

					partition@a00000 {
						label = "kernel-initramfs";
						reg = <0xa00000 0x1600000>;
					};

					partition@2000000 {
						label = "unallocated";
						reg = <0x2000000 0x2000000>;
					};
				};
			};
		};

		mmc@1560000 {
			clock-frequency = <0x11e1a300>;
			compatible = "fsl,ls1046a-esdhc", "fsl,esdhc";
			reg = <0x00 0x1560000 0x00 0x10000>;
			interrupts = <0x00 0x3e 0x04>;
			clocks = <0x02 0x02 0x01>;
			voltage-ranges = <0x708 0x708 0xce4 0xce4>;
			sdhci,auto-cmd12;
			bus-width = <0x04>;
			status = "okay";
			mmc-hs200-1_8v;
			dma-coherent;
		};

		scfg@1570000 {
			compatible = "fsl,ls1046a-scfg", "syscon";
			reg = <0x00 0x1570000 0x00 0x10000>;
			big-endian;
			#address-cells = <0x01>;
			#size-cells = <0x01>;
			ranges = <0x00 0x00 0x1570000 0x10000>;
			dma-coherent;

			interrupt-controller@1ac {
				compatible = "fsl,ls1046a-extirq", "fsl,ls1043a-extirq";
				#interrupt-cells = <0x02>;
				#address-cells = <0x00>;
				interrupt-controller;
				reg = <0x1ac 0x04>;
				interrupt-map = <0x00 0x00 0x01 0x00 0x83 0x04 0x01 0x00 0x01 0x00 0x84 0x04 0x02 0x00 0x01 0x00 0x85 0x04 0x03 0x00 0x01 0x00 0x87 0x04 0x04 0x00 0x01 0x00 0x88 0x04 0x05 0x00 0x01 0x00 0x89 0x04 0x06 0x00 0x01 0x00 0x91 0x04 0x07 0x00 0x01 0x00 0x92 0x04 0x08 0x00 0x01 0x00 0x93 0x04 0x09 0x00 0x01 0x00 0x95 0x04 0x0a 0x00 0x01 0x00 0x96 0x04 0x0b 0x00 0x01 0x00 0x97 0x04>;
				interrupt-map-mask = <0x0f 0x00>;
			};
		};

		crypto@1700000 {
			compatible = "fsl,sec-v5.4", "fsl,sec-v5.0", "fsl,sec-v4.0";
			fsl,sec-era = <0x08>;
			#address-cells = <0x01>;
			#size-cells = <0x01>;
			ranges = <0x00 0x00 0x1700000 0x100000>;
			reg = <0x00 0x1700000 0x00 0x100000>;
			interrupts = <0x00 0x4b 0x04>;
			dma-coherent;

			jr@10000 {
				compatible = "fsl,sec-v5.4-job-ring", "fsl,sec-v5.0-job-ring", "fsl,sec-v4.0-job-ring";
				reg = <0x10000 0x10000>;
				interrupts = <0x00 0x47 0x04>;
			};

			jr@20000 {
				compatible = "fsl,sec-v5.4-job-ring", "fsl,sec-v5.0-job-ring", "fsl,sec-v4.0-job-ring";
				reg = <0x20000 0x10000>;
				interrupts = <0x00 0x48 0x04>;
			};

			jr@30000 {
				compatible = "fsl,sec-v5.4-job-ring", "fsl,sec-v5.0-job-ring", "fsl,sec-v4.0-job-ring";
				reg = <0x30000 0x10000>;
				interrupts = <0x00 0x49 0x04>;
			};
		};

		qman@1880000 {
			clock-frequency = <0x11e1a300>;
			compatible = "fsl,qman";
			reg = <0x00 0x1880000 0x00 0x10000>;
			interrupts = <0x00 0x2d 0x04>;
			memory-region = <0x0c 0x0d>;
			dma-coherent;
		};

		bman@1890000 {
			compatible = "fsl,bman";
			reg = <0x00 0x1890000 0x00 0x10000>;
			interrupts = <0x00 0x2d 0x04>;
			memory-region = <0x0e>;
			dma-coherent;
		};

		qman-portals-bus@500000000 {
			ranges = <0x00 0x05 0x00 0x8000000>;
			#address-cells = <0x01>;
			#size-cells = <0x01>;
			compatible = "simple-bus";
			dma-coherent;

			qman-portal@0 {
				compatible = "fsl,qman-portal-3.2.1", "fsl,qman-portal";
				reg = <0x00 0x4000 0x4000000 0x4000>;
				interrupts = <0x00 0xac 0x04>;
				cell-index = <0x00>;
			};

			qman-portal@10000 {
				compatible = "fsl,qman-portal-3.2.1", "fsl,qman-portal";
				reg = <0x10000 0x4000 0x4010000 0x4000>;
				interrupts = <0x00 0xae 0x04>;
				cell-index = <0x01>;
			};

			qman-portal@20000 {
				compatible = "fsl,qman-portal-3.2.1", "fsl,qman-portal";
				reg = <0x20000 0x4000 0x4020000 0x4000>;
				interrupts = <0x00 0xb0 0x04>;
				cell-index = <0x02>;
			};

			qman-portal@30000 {
				compatible = "fsl,qman-portal-3.2.1", "fsl,qman-portal";
				reg = <0x30000 0x4000 0x4030000 0x4000>;
				interrupts = <0x00 0xb2 0x04>;
				cell-index = <0x03>;
			};

			qman-portal@40000 {
				compatible = "fsl,qman-portal-3.2.1", "fsl,qman-portal";
				reg = <0x40000 0x4000 0x4040000 0x4000>;
				interrupts = <0x00 0xb4 0x04>;
				cell-index = <0x04>;
			};

			qman-portal@50000 {
				compatible = "fsl,qman-portal-3.2.1", "fsl,qman-portal";
				reg = <0x50000 0x4000 0x4050000 0x4000>;
				interrupts = <0x00 0xb6 0x04>;
				cell-index = <0x05>;
			};

			qman-portal@60000 {
				compatible = "fsl,qman-portal-3.2.1", "fsl,qman-portal";
				reg = <0x60000 0x4000 0x4060000 0x4000>;
				interrupts = <0x00 0xb8 0x04>;
				cell-index = <0x06>;
			};

			qman-portal@70000 {
				compatible = "fsl,qman-portal-3.2.1", "fsl,qman-portal";
				reg = <0x70000 0x4000 0x4070000 0x4000>;
				interrupts = <0x00 0xba 0x04>;
				cell-index = <0x07>;
			};

			qman-portal@80000 {
				compatible = "fsl,qman-portal-3.2.1", "fsl,qman-portal";
				reg = <0x80000 0x4000 0x4080000 0x4000>;
				interrupts = <0x00 0xbc 0x04>;
				cell-index = <0x08>;
			};

			qman-portal@90000 {
				compatible = "fsl,qman-portal-3.2.1", "fsl,qman-portal";
				reg = <0x90000 0x4000 0x4090000 0x4000>;
				interrupts = <0x00 0xbe 0x04>;
				cell-index = <0x09>;
			};

			qman-fqids@0 {
				compatible = "fsl,fqid-range";
				fsl,fqid-range = <0x100 0x100>;
			};

			qman-fqids@1 {
				compatible = "fsl,fqid-range";
				fsl,fqid-range = <0x8000 0x8000>;
			};

			qman-pools@0 {
				compatible = "fsl,pool-channel-range";
