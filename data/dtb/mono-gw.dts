				compatible = "nxp,pca9545";
				reg = <0x70>;
				#address-cells = <0x01>;
				#size-cells = <0x00>;

				i2c@0 {
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					reg = <0x00>;
					phandle = <0x42>;
				};

				i2c@1 {
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					reg = <0x01>;
					phandle = <0x45>;
				};
			};
		};

		i2c@21a0000 {
			compatible = "fsl,ls1046a-i2c", "fsl,vf610-i2c";
			#address-cells = <0x01>;
			#size-cells = <0x00>;
			reg = <0x00 0x21a0000 0x00 0x10000>;
			interrupts = <0x00 0x3a 0x04>;
			clocks = <0x02 0x04 0x01>;
			scl-gpios = <0x12 0x0a 0x06>;
			status = "okay";
			dma-coherent;

			i2c-mux@70 {
				compatible = "nxp,pca9545";
				reg = <0x70>;
				#address-cells = <0x01>;
				#size-cells = <0x00>;

				i2c@0 {
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					reg = <0x00>;

					power_sensor@40 {
						compatible = "ti,ina234";
						reg = <0x40>;
						label = "USB Power Delivery";
						#io-channel-cells = <0x01>;
						shunt-resistor = <0x3e8>;
					};

					power_sensor@41 {
						compatible = "ti,ina234";
						reg = <0x41>;
						label = "5V PSU";
						#io-channel-cells = <0x01>;
						shunt-resistor = <0x3e8>;
					};

					power_sensor@42 {
						compatible = "ti,ina234";
						reg = <0x42>;
						label = "1V Core PSU";
						#io-channel-cells = <0x01>;
						shunt-resistor = <0x3e8>;
					};

					power_sensor@43 {
						compatible = "ti,ina234";
						reg = <0x43>;
						label = "1.2V DDR PSU";
						#io-channel-cells = <0x01>;
						shunt-resistor = <0x1388>;
					};
				};

				i2c@1 {
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					reg = <0x01>;

					power_sensor@40 {
						compatible = "ti,ina234";
						reg = <0x40>;
						label = "1.35V SerDes PSU";
						#io-channel-cells = <0x01>;
						shunt-resistor = <0x1388>;
					};

					power_sensor@41 {
						compatible = "ti,ina234";
						reg = <0x41>;
						label = "1.8V PSU";
						#io-channel-cells = <0x01>;
						shunt-resistor = <0x1388>;
					};

					power_sensor@42 {
						compatible = "ti,ina234";
						reg = <0x42>;
						label = "2.5V DDR PSU";
						#io-channel-cells = <0x01>;
						shunt-resistor = <0x1388>;
					};

					power_sensor@43 {
						compatible = "ti,ina234";
						reg = <0x43>;
						label = "3.3V PSU";
						#io-channel-cells = <0x01>;
						shunt-resistor = <0x3e8>;
					};
				};

				i2c@2 {
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					reg = <0x02>;

					rtc@53 {
						compatible = "nxp,pcf2131";
						reg = <0x53>;
						status = "okay";
					};

					hd3ss3220@47 {
						compatible = "ti,hd3ss3220";
						reg = <0x47>;
					};
				};

				i2c@3 {
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					reg = <0x03>;

					lp5810@6c {
						compatible = "ti,lp5812";
						reg = <0x6c>;
						#address-cells = <0x01>;
						#size-cells = <0x00>;

						led@0 {
							reg = <0x00>;
							color = <0x00>;
							label = "status:white";
							led-max-microamp = <0x639c>;
						};

						led@1 {
							reg = <0x01>;
							color = <0x03>;
							label = "status:blue";
							led-max-microamp = <0x639c>;
						};

						led@2 {
							reg = <0x02>;
							color = <0x02>;
							label = "status:green";
							led-max-microamp = <0x639c>;
						};

						led@3 {
							reg = <0x03>;
							color = <0x01>;
							label = "status:red";
							led-max-microamp = <0x639c>;
						};
					};
				};
			};
		};

