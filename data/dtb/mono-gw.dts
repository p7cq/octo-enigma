			compatible = "fsl,fman-ptp-timer", "fsl,fman-rtc";
			reg = <0x00 0x1afe000 0x00 0x1000>;
			interrupts = <0x00 0x2c 0x04>;
			clocks = <0x02 0x03 0x00>;
			fsl,extts-fifo;
			dma-coherent;
			phandle = <0x17>;
		};

		fsl,dpaa {
			compatible = "fsl,ls1043a-dpaa", "simple-bus", "fsl,dpaa";
			dma-coherent;

			ethernet@0 {
				compatible = "fsl,dpa-ethernet";
				fsl,fman-mac = <0x39>;
				dma-coherent;
				status = "disabled";
			};

			ethernet@1 {
				compatible = "fsl,dpa-ethernet";
				fsl,fman-mac = <0x3a>;
				dma-coherent;
			};

			ethernet@2 {
				compatible = "fsl,dpa-ethernet";
				fsl,fman-mac = <0x3b>;
				dma-coherent;
				status = "disabled";
