			fsl,tmu-range = <0xb0000 0x9002a 0x6004c 0x70062>;
			fsl,tmu-calibration = <0x00 0x23 0x01 0x29 0x02 0x2f 0x03 0x36 0x04 0x3c 0x05 0x42 0x06 0x49 0x07 0x4f 0x08 0x55 0x09 0x5c 0x0a 0x62 0x0b 0x68 0x10000 0x22 0x10001 0x2a 0x10002 0x32 0x10003 0x3a 0x10004 0x42 0x10005 0x4a 0x10006 0x52 0x10007 0x5a 0x10008 0x62 0x10009 0x6a 0x20000 0x21 0x20001 0x2b 0x20002 0x35 0x20003 0x3e 0x20004 0x48 0x20005 0x52 0x20006 0x5c 0x30000 0x11 0x30001 0x1a 0x30002 0x24 0x30003 0x2e 0x30004 0x38 0x30005 0x42 0x30006 0x4c 0x30007 0x56>;
