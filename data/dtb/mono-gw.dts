	reserved-memory {
		#address-cells = <0x02>;
		#size-cells = <0x02>;
		ranges;

		bman-fbpr {
			reg = <0x09 0xff000000 0x00 0x1000000>;
			compatible = "fsl,bman-fbpr";
			no-map;
			phandle = <0x0e>;
		};

		qman-fqd {
			reg = <0x09 0xfe800000 0x00 0x800000>;
			compatible = "fsl,qman-fqd";
			no-map;
			phandle = <0x0c>;
		};

		qman-pfdr {
			reg = <0x09 0xfc000000 0x00 0x2000000>;
			compatible = "fsl,qman-pfdr";
			no-map;
			phandle = <0x0d>;
		};
	};

	firmware {

		optee {
			compatible = "linaro,optee-tz";
			method = "smc";
		};
	};

	chosen {
		kaslr-seed = <0xe8628ae3 0xda59724a>;
		u-boot,bootconf = "config-1";
		u-boot,version = "2025.04-g26d27571ac82-dirty";
		bootargs = "console=ttyS0,115200 earlycon=uart8250,mmio,0x21c0500 mtdparts=${mtdparts} root=/dev/mmcblk0p1 rw rootwait rootfstype=ext4 ";
		stdout-path = "serial0:115200n8";
	};

	leds {
		compatible = "gpio-leds";

		sfp0_link {
			label = "sfp0:link";
			gpios = <0x41 0x11 0x00>;
			default-state = "off";
			phandle = <0x43>;
		};

		sfp0_activity {
			label = "sfp0:activity";
			gpios = <0x41 0x12 0x00>;
			default-state = "off";
			phandle = <0x44>;
		};

		sfp1_link {
			label = "sfp1:link";
			gpios = <0x41 0x0f 0x00>;
			default-state = "off";
			phandle = <0x46>;
		};

		sfp1_activity {
			label = "sfp1:activity";
			gpios = <0x41 0x10 0x00>;
			default-state = "off";
			phandle = <0x47>;
		};
	};

	sfp-xfi0 {
		compatible = "sff,sfp";
		i2c-bus = <0x42>;
		tx-disable-gpios = <0x41 0x0e 0x00>;
		mod-def0-gpios = <0x41 0x0c 0x01>;
		los-gpios = <0x41 0x0b 0x00>;
		maximum-power-milliwatt = <0xbb8>;
		leds = <0x43 0x44>;
		phandle = <0x31>;
	};

	sfp-xfi1 {
		compatible = "sff,sfp";
		i2c-bus = <0x45>;
		tx-disable-gpios = <0x41 0x0d 0x00>;
		mod-def0-gpios = <0x41 0x0a 0x01>;
		los-gpios = <0x41 0x09 0x00>;
		maximum-power-milliwatt = <0xbb8>;
		leds = <0x46 0x47>;
		phandle = <0x36>;
	};

	sfp-led-controller {
		compatible = "mono,sfp-led";
		sfp-ports = <0x31 0x36>;
	};

	bootmem0@a0000000 {
		reg = <0x00 0xa0000000 0x00 0x4000000 0x00 0xa4000000 0x00 0x6000000>;
	};

	bootmem1@aa000000 {
		reg = <0x00 0xaa000000 0x00 0x4000000 0x00 0xae000000 0x00 0x6000000>;
	};
};
