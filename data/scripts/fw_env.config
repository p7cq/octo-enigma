# /etc/fw_env.config — U-Boot environment access configuration
# Used by fw_printenv / fw_setenv (u-boot-tools package)
#
# Mono Gateway LS1046A: U-Boot env is stored in SPI NOR flash (mtd3)
# Format: Device          Offset      Env size  Flash sector size
/dev/mtd2                 0x100000    0x2000    0x1000
