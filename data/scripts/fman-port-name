#!/bin/bash
# Map FMan MAC device-tree addresses to physical port names on Mono Gateway DK.
# Called by udev rule 10-fman-port-order.rules via PROGRAM=.
# Outputs the desired interface name; udev uses it via NAME="%c".
#
# NOTE: On installed systems, VyOS's vyos_net_name (hw-id matching from
# config.boot) takes precedence over this udev rule. This script is
# primarily effective during live boot (no config.boot) and serves as
# documentation of the correct physical mapping.
#
# DT MAC addresses confirmed via /sys/firmware/devicetree/base/soc/fman@.../local-mac-address:
#   ethernet@e8000  (MAC5, 16:00)  → eth0  left RJ45
#   ethernet@ea000  (MAC6, 16:01)  → eth1  center RJ45
#   ethernet@e2000  (MAC2, 15:ff)  → eth2  right RJ45
#   ethernet@f0000  (MAC9, 16:02)  → eth3  left SFP+
#   ethernet@f2000  (MAC10, 16:03) → eth4  right SFP+

IFACE="$1"
[ -z "$IFACE" ] && exit 1

# Resolve the device-tree node for this network interface.
# For DPAA1, /sys/class/net/<iface>/device/of_node is a symlink
# to /proc/device-tree/soc/.../fman@.../ethernet@XXXXX
OF_NODE=$(readlink -f "/sys/class/net/$IFACE/device/of_node" 2>/dev/null)

# If no of_node, this is not a DT-based interface — keep original name
if [ -z "$OF_NODE" ]; then
    echo "$IFACE"
    exit 0
fi

# Extract the ethernet@XXXXX node name from the path
case "$OF_NODE" in
    *ethernet@e8000)  echo "eth0" ;;  # MAC5  - left RJ45
    *ethernet@ea000)  echo "eth1" ;;  # MAC6  - center RJ45
    *ethernet@e2000)  echo "eth2" ;;  # MAC2  - right RJ45
    *ethernet@f0000)  echo "eth3" ;;  # MAC9  - left SFP+
    *ethernet@f2000)  echo "eth4" ;;  # MAC10 - right SFP+
    *)                echo "$IFACE" ;; # unknown MAC, keep original name
esac
