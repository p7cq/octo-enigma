#!/bin/bash
# vyos-postinstall — Seamless boot helper for LS1046A U-Boot boards
#
# Two responsibilities:
#   1. ALWAYS: Write /boot/vyos.env so U-Boot knows which image to boot
#   2. ONE-TIME: Set static U-Boot env vars (bootcmd, vyos_direct, usb_vyos)
#      via fw_setenv — only if vyos_direct doesn't already contain "vyos.env"
#
# After the one-time setup, all future installs/upgrades only need step 1:
# a single text file write on the eMMC ext4 partition. No SPI flash writes.
#
# Usage:
#   sudo vyos-postinstall              # auto-detect latest image
#   sudo vyos-postinstall <image-name> # explicit image
#
# This script is a no-op on non-LS1046A hardware.

set -euo pipefail

VYOS_ENV_FILE="vyos.env"
FW_ENV_CONFIG="/etc/fw_env.config"
UBOOT_BOOTARGS_TAIL="console=ttyS0,115200 earlycon=uart8250,mmio,0x21c0500 net.ifnames=0 boot=live rootdelay=5 noautologin fsl_dpaa_fman.fsl_fm_max_frm=9600 hugepagesz=2M hugepages=512 panic=60"

#--- Board detection ---
check_board() {
    local compat="/proc/device-tree/compatible"
    if [ ! -f "$compat" ]; then
        echo "Not running on a DeviceTree platform. Skipping."
        exit 0
    fi
    if ! tr '\0' '\n' < "$compat" | grep -q "fsl,ls1046a"; then
        echo "Not an LS1046A board. Skipping."
        exit 0
    fi
}

#--- Find persistence root (where /boot/{image}/ lives on eMMC) ---
find_root() {
    for candidate in "/" "/mnt/root" "/mnt"; do
        candidate='/usr/lib/live/mount/persistence'
        if [ -d "${candidate}/boot" ]; then
            local images
            images=$(find "${candidate}/boot" -maxdepth 1 -mindepth 1 -type d \
                -name '20*-*-rolling' 2>/dev/null | wc -l)
            if [ "$images" -gt 0 ]; then
                echo "$candidate"
                return 0
            fi
        fi
    done
    while IFS= read -r mpoint; do
        if [ -d "${mpoint}/boot" ]; then
            local images
            images=$(find "${mpoint}/boot" -maxdepth 1 -mindepth 1 -type d \
                -name '20*-*-rolling' 2>/dev/null | wc -l)
            if [ "$images" -gt 0 ]; then
                echo "$mpoint"
                return 0
            fi
        fi
    done < <(mount | awk '{print $3}' | grep -v -E '^/(proc|sys|dev|run)')
    echo "ERROR: Cannot find persistence root with VyOS image directories in /boot/" >&2
    return 1
}

#--- Auto-detect latest image by version string ---
detect_latest_image() {
    local root="$1"
    find "${root}/boot" -maxdepth 1 -mindepth 1 -type d -name '20*-*-rolling' \
        -printf '%f\n' 2>/dev/null | sort -r | head -1
}

#--- Write /boot/vyos.env ---
write_vyos_env() {
    local image_name="$1"
    local root="$2"
    local env_path="${root}/boot/${VYOS_ENV_FILE}"

    echo "vyos_image=${image_name}" > "$env_path"
    echo "✓ Written: ${env_path} → vyos_image=${image_name}"
}

#--- One-time U-Boot env setup (static vyos_direct that reads vyos.env) ---
setup_uboot_env_once() {
    # Skip if vyos_direct already contains "vyos.env" (already set up)
    if command -v fw_printenv &>/dev/null && [ -f "$FW_ENV_CONFIG" ]; then
        local current
        current=$(fw_printenv vyos_direct 2>/dev/null || echo "")
        if echo "$current" | grep -q "vyos.env"; then
            echo "✓ U-Boot env already configured (vyos_direct references vyos.env). Skipping fw_setenv."
            return 0
        fi
    else
        echo "WARNING: fw_printenv/fw_setenv not available or ${FW_ENV_CONFIG} missing."
        echo "  One-time U-Boot setup skipped. Set these manually in U-Boot console:"
        echo "  See INSTALL.md for the commands."
        return 0
    fi

    echo "First-time U-Boot setup: writing static vyos_direct + usb_vyos + bootcmd..."

    # Static vyos_direct: reads /boot/vyos.env, imports vyos_image, loads kernel/dtb/initrd
    # CRITICAL: initrd loaded LAST so ${filesize} captures its size for booti
    # CRITICAL: BOOT_IMAGE= must be in bootargs for VyOS is_live_boot() detection
    local vyos_direct
    vyos_direct='ext4load mmc 0:3 ${load_addr} /boot/vyos.env; env import -t ${load_addr} ${filesize}; ext4load mmc 0:3 ${kernel_addr_r} /boot/${vyos_image}/vmlinuz; ext4load mmc 0:3 ${fdt_addr_r} /boot/${vyos_image}/mono-gw.dtb; ext4load mmc 0:3 ${ramdisk_addr_r} /boot/${vyos_image}/initrd.img; setenv bootargs "BOOT_IMAGE=/boot/${vyos_image}/vmlinuz '"${UBOOT_BOOTARGS_TAIL}"' vyos-union=/boot/${vyos_image}"; booti ${kernel_addr_r} ${ramdisk_addr_r}:${filesize} ${fdt_addr_r}'

    # USB auto-boot: try FAT32 USB first (for re-installs without U-Boot interaction)
    local usb_vyos
    usb_vyos='usb start; if fatload usb 0:1 ${kernel_addr_r} live/vmlinuz; then fatload usb 0:1 ${fdt_addr_r} mono-gw.dtb; fatload usb 0:1 ${ramdisk_addr_r} live/initrd.img; setenv bootargs "BOOT_IMAGE=/live/vmlinuz console=ttyS0,115200 earlycon=uart8250,mmio,0x21c0500 boot=live live-media=/dev/sda1 components noeject nopersistence noautologin nonetworking union=overlay net.ifnames=0 fsl_dpaa_fman.fsl_fm_max_frm=9600 quiet"; booti ${kernel_addr_r} ${ramdisk_addr_r}:${filesize} ${fdt_addr_r}; fi'

    fw_setenv vyos_direct "$vyos_direct"
    fw_setenv usb_vyos "$usb_vyos"
    fw_setenv bootcmd "run usb_vyos || run vyos_direct || run recovery"

    echo "✓ U-Boot: vyos_direct → static (reads /boot/vyos.env)"
    echo "✓ U-Boot: usb_vyos → auto-detect USB live boot"
    echo "✓ U-Boot: bootcmd → 'run usb_vyos || run vyos_direct || run recovery'"
}

#--- Main ---
main() {
    check_board

    local mp='/mnt'
    local root="${mp}/boot"
    # root=$(find_root)
    mount /dev/mmcblk0p3 "${mp}"

    local image_name="${1:-}"

    if [ -z "$image_name" ]; then
        image_name=$(detect_latest_image "$root")
        if [ -n "$image_name" ]; then
            echo "Auto-detected image: ${image_name}"
        else
            echo "ERROR: No VyOS image found. Specify image name as argument." >&2
            exit 1
        fi
    fi

    if [ ! -d "${root}/boot/${image_name}" ]; then
        echo "ERROR: Image '${image_name}' not found at ${root}/boot/${image_name}" >&2
        exit 1
    fi

    echo "=== VyOS Post-Install for LS1046A ==="
    echo "Image:  ${image_name}"
    echo "Root:   ${root}"
    echo ""

    write_vyos_env "$image_name" "$root"
    [[ "$(lsblk /dev/mmcblk0p3 -no mountpoints)" == "${mp}" ]] && umount "${mp}"
    setup_uboot_env_once

    echo ""
    echo "=== Done. Reboot to boot from eMMC. ==="
}

main "$@"
